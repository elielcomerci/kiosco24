/execute-out.txt
/lint_results.txt
/prisma_error.txt
/query_output.txt
/readable_lint.txt
/test*.py
/test*.html
/tmp_*.html
/tmp_diff.txt
/ts-error.txt
/ts_err*.txt
/ts_error.txt
/tsc_errors.txt
/tsc_output*.txt
/typescript-errors.txt
/users.txt
/tools/platform-scraper-rs/coto_output.txt
/tools/platform-scraper-rs/output.txt
