generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                        String                      @id @default(cuid())
  name                      String?
  email                     String                      @unique
  password                  String?
  emailVerified             DateTime?
  image                     String?
  role                      UserRole                    @default(OWNER)
  accounts                  Account[]
  sessions                  Session[]
  kiosco                    Kiosco?
  createdAccessGrants       AccessGrant[]               @relation("AccessGrantCreator")
  accessOverrideChanges     Kiosco[]                    @relation("KioscoAccessOverrideBy")
  submittedPlatformProducts PlatformProductSubmission[] @relation("PlatformProductSubmissionSubmitter")
  reviewedPlatformProducts  PlatformProductSubmission[] @relation("PlatformProductSubmissionReviewer")
  createdAt                 DateTime                    @default(now())
  updatedAt                 DateTime                    @updatedAt
}

enum UserRole {
  OWNER
  EMPLOYEE
  PLATFORM_ADMIN
}

enum PricingMode {
  SHARED
  BRANCH
}

enum FiscalEnvironment {
  TEST
  PROD
}

enum FiscalVatCondition {
  MONOTRIBUTO
  RESP_INSCRIPTO
}

enum InvoiceStatus {
  PENDING
  ISSUED
  FAILED
}

enum TicketPrintMode {
  STANDARD
  THERMAL_58
  THERMAL_80
}

enum PlatformSyncMode {
  MANUAL
  AUTO
}

enum ShiftReminderDelivery {
  NEXT_SHIFT
  SCHEDULED
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Kiosco {
  id                         String                      @id @default(cuid())
  name                       String
  ownerId                    String                      @unique
  owner                      User                        @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  branches                   Branch[]
  products                   Product[]
  categories                 Category[]
  expiryAlertDays            Int                         @default(30)
  pricingMode                PricingMode                 @default(BRANCH)
  subscription               Subscription?
  employees                  Employee[]
  accessGrants               AccessGrant[]
  accessOverride             KioscoAccessOverride        @default(INHERIT)
  accessOverrideNote         String?                     @db.Text
  accessOverrideAt           DateTime?
  accessOverrideById         String?
  accessOverrideBy           User?                       @relation("KioscoAccessOverrideBy", fields: [accessOverrideById], references: [id], onDelete: SetNull)
  fiscalProfile              FiscalProfile?
  platformProductSubmissions PlatformProductSubmission[]
  createdAt                  DateTime                    @default(now())
  updatedAt                  DateTime                    @updatedAt
}

model Branch {
  id                 String             @id @default(cuid())
  name               String
  address            String?
  phone              String?
  kioscoId           String
  kiosco             Kiosco             @relation(fields: [kioscoId], references: [id], onDelete: Cascade)
  activeShiftId      String?            @unique
  activeShift        Shift?             @relation("BranchActiveShift", fields: [activeShiftId], references: [id], onDelete: SetNull)
  employees          Employee[]
  inventory          InventoryRecord[]
  sales              Sale[]
  shifts             Shift[]
  expenses           Expense[]
  withdrawals        Withdrawal[]
  customers          CreditCustomer[]
  logoUrl            String?
  primaryColor       String?            @default("#22c55e")
  bgColor            String?            @default("#0f172a")
  ownerPin           String?
  allowNegativeStock Boolean            @default(false)
  ticketCounter      Int                @default(0)
  accessKey          String?            @unique // Código para vincular dispositivos
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt
  variantInventories VariantInventory[]

  // MercadoPago OAuth — tokens de la cuenta MP de esta sucursal
  mpUserId                 String? // ID numérico de la cuenta MP del dueño
  mpAccessToken            String?                   @db.Text
  mpRefreshToken           String?                   @db.Text
  mpTokenExpiresAt         DateTime? // access_token dura 180 días
  mpStoreId                String? // ID de sucursal creada en MP
  mpPosId                  String? // external_id del punto de venta en MP
  mpIncomingPaymentNotices MpIncomingPaymentNotice[]
  restockEvents            RestockEvent[]
  inventoryCostLayers      InventoryCostLayer[]
  saleCostAllocations      SaleCostAllocation[]
  negativeStockReservations NegativeStockReservation[]
  stockLots                StockLot[]
  ticketSettings           TicketSettings?
  fiscalSettings           BranchFiscalSettings?
  invoices                 Invoice[]
  shiftReminders           ShiftReminder[]

  @@index([kioscoId])
}

model FiscalProfile {
  id               String              @id @default(cuid())
  kioscoId         String              @unique
  kiosco           Kiosco              @relation(fields: [kioscoId], references: [id], onDelete: Cascade)
  cuit             String
  afipAccessToken  String?             @db.Text
  razonSocial      String
  domicilioFiscal  String
  condicionIva     FiscalVatCondition  @default(MONOTRIBUTO)
  inicioActividad  String
  ingresosBrutos   String?
  environment      FiscalEnvironment   @default(TEST)
  createdAt        DateTime            @default(now())
  updatedAt        DateTime            @updatedAt
}

model BranchFiscalSettings {
  id                   String    @id @default(cuid())
  branchId             String    @unique
  branch               Branch    @relation(fields: [branchId], references: [id], onDelete: Cascade)
  activo               Boolean   @default(false)
  puntoDeVenta         Int?
  minimumInvoiceAmount Float     @default(0)
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt
}

model TicketSettings {
  id             String   @id @default(cuid())
  branchId       String   @unique
  branch         Branch   @relation(fields: [branchId], references: [id], onDelete: Cascade)
  showLogo       Boolean  @default(true)
  showAddress    Boolean  @default(false)
  showPhone      Boolean  @default(false)
  showFooterText Boolean  @default(true)
  footerText     String?  @default("¡Gracias por su compra!")
  orderLink      String?
  printMode      TicketPrintMode @default(STANDARD)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model Category {
  id         String    @id @default(cuid())
  name       String
  color      String?
  showInGrid Boolean   @default(true)
  kioscoId   String
  kiosco     Kiosco    @relation(fields: [kioscoId], references: [id], onDelete: Cascade)
  products   Product[]
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  @@index([kioscoId])
}

model Product {
  id                String            @id @default(cuid())
  name              String
  barcode           String?
  internalCode      String?
  emoji             String?
  image             String? // Cloudinary URL
  brand             String?
  description       String?
  presentation      String?
  supplierName      String?
  notes             String?           @db.Text
  categoryId        String?
  category          Category?         @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  platformProductId String?
  platformProduct   PlatformProduct?  @relation(fields: [platformProductId], references: [id], onDelete: SetNull)
  platformSyncMode  PlatformSyncMode  @default(MANUAL)
  platformSourceUpdatedAt DateTime?
  kioscoId          String
  kiosco            Kiosco            @relation(fields: [kioscoId], references: [id], onDelete: Cascade)
  inventory         InventoryRecord[]
  inventoryCostLayers InventoryCostLayer[]
  saleCostAllocations SaleCostAllocation[]
  negativeStockReservations NegativeStockReservation[]
  variants          Variant[]
  restocks          RestockItem[]
  stockLots         StockLot[]
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt

  @@index([kioscoId])
  @@index([categoryId])
  @@index([barcode])
  @@index([internalCode])
  @@index([platformProductId])
}

model PlatformProduct {
  id           String                      @id @default(cuid())
  barcode      String?                     @unique
  name         String
  brand        String?
  categoryName String?
  description  String?
  presentation String?
  image        String?
  status       PlatformProductStatus       @default(APPROVED)
  products     Product[]
  variants     PlatformProductVariant[]
  submissions  PlatformProductSubmission[]
  createdAt    DateTime                    @default(now())
  updatedAt    DateTime                    @updatedAt

  @@index([status])
}

model PlatformProductVariant {
  id                String          @id @default(cuid())
  name              String
  barcode           String?         @unique
  platformProductId String
  platformProduct   PlatformProduct @relation(fields: [platformProductId], references: [id], onDelete: Cascade)
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt

  @@index([platformProductId])
}

model PlatformProductSubmission {
  id                    String                             @id @default(cuid())
  barcode               String?
  name                  String
  brand                 String?
  categoryName          String?
  description           String?
  presentation          String?
  image                 String?
  status                PlatformProductSubmissionStatus    @default(PENDING)
  reviewNote            String?                            @db.Text
  platformProductId     String?
  platformProduct       PlatformProduct?                   @relation(fields: [platformProductId], references: [id], onDelete: SetNull)
  submittedByUserId     String?
  submittedByUser       User?                              @relation("PlatformProductSubmissionSubmitter", fields: [submittedByUserId], references: [id], onDelete: SetNull)
  submittedFromKioscoId String?
  submittedFromKiosco   Kiosco?                            @relation(fields: [submittedFromKioscoId], references: [id], onDelete: SetNull)
  reviewedById          String?
  reviewedBy            User?                              @relation("PlatformProductSubmissionReviewer", fields: [reviewedById], references: [id], onDelete: SetNull)
  reviewedAt            DateTime?
  variants              PlatformProductSubmissionVariant[]
  createdAt             DateTime                           @default(now())
  updatedAt             DateTime                           @updatedAt

  @@index([barcode, status])
  @@index([submittedByUserId])
  @@index([submittedFromKioscoId])
  @@index([platformProductId])
}

model PlatformProductSubmissionVariant {
  id           String                    @id @default(cuid())
  name         String
  barcode      String?
  submissionId String
  submission   PlatformProductSubmission @relation(fields: [submissionId], references: [id], onDelete: Cascade)
  createdAt    DateTime                  @default(now())
  updatedAt    DateTime                  @updatedAt

  @@index([submissionId])
}

model InventoryRecord {
  id         String  @id @default(cuid())
  price      Float
  cost       Float?
  stock      Int?
  minStock   Int?
  showInGrid Boolean @default(true)
  productId  String
  product    Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  branchId   String
  branch     Branch  @relation(fields: [branchId], references: [id], onDelete: Cascade)

  @@unique([productId, branchId])
  @@index([branchId])
}

model Variant {
  id        String   @id @default(cuid())
  name      String
  barcode   String?
  internalCode String?
  productId String
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  inventory VariantInventory[]
  inventoryCostLayers InventoryCostLayer[]
  saleCostAllocations SaleCostAllocation[]
  negativeStockReservations NegativeStockReservation[]
  restocks  RestockItem[]
  stockLots StockLot[]

  @@index([productId])
  @@index([barcode])
  @@index([internalCode])
}

model VariantInventory {
  id       String @id @default(cuid())
  stock    Int?
  minStock Int?
  price    Float?
  cost     Float?

  variantId String
  variant   Variant @relation(fields: [variantId], references: [id], onDelete: Cascade)

  branchId String
  branch   Branch @relation(fields: [branchId], references: [id], onDelete: Cascade)

  @@unique([variantId, branchId])
  @@index([branchId])
}

enum EmployeeRole {
  CASHIER
  MANAGER
}

model Employee {
  id             String         @id @default(cuid())
  name           String
  pin            String?
  active         Boolean        @default(true)
  suspendedUntil DateTime? // Suspensión temporal
  role           EmployeeRole   @default(CASHIER)
  kioscoId       String
  kiosco         Kiosco         @relation(fields: [kioscoId], references: [id], onDelete: Cascade)
  branches       Branch[]
  shifts         Shift[]
  restockEvents  RestockEvent[]
  sales          Sale[]         @relation("CreatedBy")
  expenses       Expense[]      @relation("CreatedBy")
  withdrawals    Withdrawal[]   @relation("CreatedBy")

  @@index([kioscoId])
}

model Shift {
  id              String       @id @default(cuid())
  employeeId      String?
  employee        Employee?    @relation(fields: [employeeId], references: [id])
  employeeName    String
  branchId        String
  branch          Branch       @relation(fields: [branchId], references: [id], onDelete: Cascade)
  activeForBranch Branch?      @relation("BranchActiveShift")
  openingAmount   Float
  closingAmount   Float?
  expectedAmount  Float?
  difference      Float?
  note            String?
  openedAt        DateTime     @default(now())
  closedAt        DateTime?
  sales           Sale[]
  expenses        Expense[]
  withdrawals     Withdrawal[]

  @@index([branchId, openedAt])
}

model ShiftReminder {
  id                 String                @id @default(cuid())
  branchId           String
  branch             Branch                @relation(fields: [branchId], references: [id], onDelete: Cascade)
  message            String                @db.Text
  delivery           ShiftReminderDelivery @default(NEXT_SHIFT)
  scheduledFor       DateTime?
  createdDuringShiftId String?
  shownToShiftId     String?
  createdByEmployeeId String?
  createdByLabel     String
  shownAt            DateTime?
  createdAt          DateTime              @default(now())
  updatedAt          DateTime              @updatedAt

  @@index([branchId, shownAt, createdAt])
  @@index([branchId, delivery, scheduledFor])
}

model Expense {
  id                  String        @id @default(cuid())
  amount              Float
  reason              ExpenseReason
  note                String?
  shiftId             String?
  shift               Shift?        @relation(fields: [shiftId], references: [id], onDelete: SetNull)
  branchId            String
  branch              Branch        @relation(fields: [branchId], references: [id], onDelete: Cascade)
  createdByEmployeeId String?
  createdByEmployee   Employee?     @relation("CreatedBy", fields: [createdByEmployeeId], references: [id], onDelete: SetNull)
  createdAt           DateTime      @default(now())

  @@index([branchId, createdAt])
}

model Withdrawal {
  id                  String    @id @default(cuid())
  amount              Float
  note                String?
  shiftId             String?
  shift               Shift?    @relation(fields: [shiftId], references: [id], onDelete: SetNull)
  branchId            String
  branch              Branch    @relation(fields: [branchId], references: [id], onDelete: Cascade)
  createdByEmployeeId String?
  createdByEmployee   Employee? @relation("CreatedBy", fields: [createdByEmployeeId], references: [id], onDelete: SetNull)
  createdAt           DateTime  @default(now())

  @@index([branchId, createdAt])
}

model Sale {
  id                  String          @id @default(cuid())
  clientSaleId        String?
  total               Float
  paymentMethod       PaymentMethod
  receivedAmount      Float?
  ticketNumber        Int?
  ticketIssuedAt      DateTime?
  ticketMetaSnapshot  Json?
  shiftId             String?
  shift               Shift?          @relation(fields: [shiftId], references: [id], onDelete: SetNull)
  branchId            String
  branch              Branch          @relation(fields: [branchId], references: [id], onDelete: Cascade)
  createdByEmployeeId String?
  createdByEmployee   Employee?       @relation("CreatedBy", fields: [createdByEmployeeId], references: [id], onDelete: SetNull)
  items               SaleItem[]
  invoice             Invoice?
  creditCustomerId    String?
  creditCustomer      CreditCustomer? @relation(fields: [creditCustomerId], references: [id], onDelete: SetNull)
  voided              Boolean         @default(false)
  voidedAt            DateTime?
  createdAt           DateTime        @default(now())

  @@unique([branchId, clientSaleId])
  @@index([branchId, createdAt])
  @@index([branchId, ticketNumber])
  @@index([shiftId])
}

model Invoice {
  id              String         @id @default(cuid())
  saleId          String         @unique
  sale            Sale           @relation(fields: [saleId], references: [id], onDelete: Cascade)
  branchId        String
  branch          Branch         @relation(fields: [branchId], references: [id], onDelete: Cascade)
  status          InvoiceStatus  @default(PENDING)
  cae             String?
  caeFchVto       DateTime?
  comprobanteTipo Int?
  comprobanteNro  Int?
  puntoDeVenta    Int?
  fechaEmision    DateTime?
  docTipo         Int
  docNro          String
  receiverName    String?
  receiverIvaConditionId Int?
  receiverIvaConditionLabel String?
  impTotal        Float
  impNeto         Float
  impIva          Float          @default(0)
  pdfBlobUrl      String?
  pdfAfipUrl      String?
  enviadoPorWa    Boolean        @default(false)
  lastError       String?        @db.Text
  afipRawResponse Json?
  emitterSnapshot Json
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  @@index([branchId, status, createdAt])
  @@index([branchId, fechaEmision])
  @@unique([branchId, comprobanteTipo, comprobanteNro])
}

model SaleItem {
  id        String  @id @default(cuid())
  saleId    String
  sale      Sale    @relation(fields: [saleId], references: [id], onDelete: Cascade)
  productId String?
  variantId String?
  name      String
  price     Float
  quantity  Int
  cost      Float?
  lotConsumptions SaleLotConsumption[]
  costAllocations SaleCostAllocation[]
  negativeStockReservations NegativeStockReservation[]
}

model CreditCustomer {
  id        String          @id @default(cuid())
  name      String
  phone     String?
  balance   Float           @default(0)
  branchId  String
  branch    Branch          @relation(fields: [branchId], references: [id], onDelete: Cascade)
  sales     Sale[]
  payments  CreditPayment[]
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt

  @@index([branchId])
}

model CreditPayment {
  id         String         @id @default(cuid())
  amount     Float
  customerId String
  customer   CreditCustomer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  createdAt  DateTime       @default(now())
}

// ── Auditoría de Stock (Ingresos de mercadería) ──────────────────────────────

enum RestockEventType {
  RECEIVE
  CORRECTION
  TRANSFER
}

enum RestockValuationStatus {
  PENDING
  COMPLETED
  NOT_APPLICABLE
}

enum InventoryCostLayerSourceType {
  RECEIVE
  LEGACY_SNAPSHOT
  MANUAL_VALUATION
}

model RestockEvent {
  id              String                 @id @default(cuid())
  type            RestockEventType       @default(RECEIVE)
  note            String?                @db.Text
  supplierName    String?
  valuationStatus RestockValuationStatus @default(PENDING)
  employeeId      String?
  employee        Employee?              @relation(fields: [employeeId], references: [id], onDelete: SetNull)
  branchId        String
  branch          Branch                 @relation(fields: [branchId], references: [id], onDelete: Cascade)
  items           RestockItem[]
  attachments     RestockAttachment[]
  createdAt       DateTime               @default(now())

  @@index([branchId])
  @@index([employeeId])
  @@index([branchId, type, createdAt])
}

model RestockItem {
  id             String       @id @default(cuid())
  restockEventId String
  restockEvent   RestockEvent @relation(fields: [restockEventId], references: [id], onDelete: Cascade)
  productId      String
  product        Product      @relation(fields: [productId], references: [id], onDelete: Cascade)
  variantId      String?
  variant        Variant?     @relation(fields: [variantId], references: [id], onDelete: Cascade)
  quantity       Int // Cantidad sumada
  unitCost       Float?
  salePrice      Float?
  inventoryCostLayers InventoryCostLayer[]

  @@index([restockEventId])
  @@index([productId])
  @@index([variantId])
}

model InventoryCostLayer {
  id             String                       @id @default(cuid())
  branchId       String
  branch         Branch                       @relation(fields: [branchId], references: [id], onDelete: Cascade)
  productId      String
  product        Product                      @relation(fields: [productId], references: [id], onDelete: Cascade)
  variantId      String?
  variant        Variant?                     @relation(fields: [variantId], references: [id], onDelete: Cascade)
  restockItemId  String?                      @unique
  restockItem    RestockItem?                 @relation(fields: [restockItemId], references: [id], onDelete: Cascade)
  sourceType     InventoryCostLayerSourceType @default(RECEIVE)
  unitCost       Float
  initialQuantity Int
  remainingQuantity Int
  saleCostAllocations SaleCostAllocation[]
  receivedAt     DateTime
  createdAt      DateTime                     @default(now())
  updatedAt      DateTime                     @updatedAt

  @@index([branchId, productId, receivedAt])
  @@index([branchId, variantId, receivedAt])
  @@index([branchId, sourceType, createdAt])
}

model SaleCostAllocation {
  id                   String             @id @default(cuid())
  saleItemId           String
  saleItem             SaleItem           @relation(fields: [saleItemId], references: [id], onDelete: Cascade)
  inventoryCostLayerId String
  inventoryCostLayer   InventoryCostLayer @relation(fields: [inventoryCostLayerId], references: [id], onDelete: Cascade)
  branchId             String
  branch               Branch             @relation(fields: [branchId], references: [id], onDelete: Cascade)
  productId            String
  product              Product            @relation(fields: [productId], references: [id], onDelete: Cascade)
  variantId            String?
  variant              Variant?           @relation(fields: [variantId], references: [id], onDelete: SetNull)
  quantity             Int
  unitCost             Float
  totalCost            Float
  createdAt            DateTime           @default(now())

  @@index([saleItemId])
  @@index([inventoryCostLayerId])
  @@index([branchId, createdAt])
  @@index([productId, createdAt])
  @@index([variantId, createdAt])
}

model NegativeStockReservation {
  id             String    @id @default(cuid())
  saleItemId     String
  saleItem       SaleItem  @relation(fields: [saleItemId], references: [id], onDelete: Cascade)
  branchId       String
  branch         Branch    @relation(fields: [branchId], references: [id], onDelete: Cascade)
  productId      String
  product        Product   @relation(fields: [productId], references: [id], onDelete: Cascade)
  variantId      String?
  variant        Variant?  @relation(fields: [variantId], references: [id], onDelete: SetNull)
  originalQuantity Int
  quantityPending Int
  resolvedAt     DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  @@index([saleItemId])
  @@index([branchId, createdAt])
  @@index([branchId, productId, resolvedAt])
  @@index([branchId, variantId, resolvedAt])
}

model RestockAttachment {
  id             String       @id @default(cuid())
  restockEventId String
  restockEvent   RestockEvent @relation(fields: [restockEventId], references: [id], onDelete: Cascade)
  url            String
  createdAt      DateTime     @default(now())

  @@index([restockEventId])
}

model StockLot {
  id        String   @id @default(cuid())
  quantity  Int
  expiresOn DateTime @db.Date
  productId String
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  variantId String?
  variant   Variant? @relation(fields: [variantId], references: [id], onDelete: Cascade)
  branchId  String
  branch    Branch   @relation(fields: [branchId], references: [id], onDelete: Cascade)
  consumptions SaleLotConsumption[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([branchId, productId, expiresOn])
  @@index([branchId, variantId, expiresOn])
}

model SaleLotConsumption {
  id        String    @id @default(cuid())
  saleItemId String
  saleItem  SaleItem  @relation(fields: [saleItemId], references: [id], onDelete: Cascade)
  stockLotId String?
  stockLot  StockLot? @relation(fields: [stockLotId], references: [id], onDelete: SetNull)
  expiresOn DateTime  @db.Date
  quantity  Int
  createdAt DateTime  @default(now())

  @@index([saleItemId])
  @@index([stockLotId])
}

model MpIncomingPaymentNotice {
  id                 String                   @id @default(cuid())
  branchId           String
  branch             Branch                   @relation(fields: [branchId], references: [id], onDelete: Cascade)
  mpPaymentId        String                   @unique
  collectorId        String?
  channel            MpIncomingPaymentChannel @default(MERCADOPAGO)
  status             String
  paymentType        String?
  paymentMethod      String?
  amount             Float
  currency           String?
  payerName          String?
  payerEmail         String?
  referenceLabel     String?
  occurredAt         DateTime?
  approvedObservedAt DateTime?
  createdAt          DateTime                 @default(now())
  updatedAt          DateTime                 @updatedAt

  @@index([branchId, createdAt])
  @@index([branchId, approvedObservedAt])
  @@index([branchId, status, approvedObservedAt])
}

enum PaymentMethod {
  CASH
  MERCADOPAGO
  TRANSFER
  DEBIT
  CREDIT_CARD
  CREDIT
}

enum ExpenseReason {
  ICE
  MERCHANDISE
  DELIVERY
  OTHER
}

// ── Suscripción mensual ───────────────────────────────────────────────────────
// Vive en Kiosco: una suscripción cubre todas las sucursales del dueño
model Subscription {
  id              String             @id @default(cuid())
  kioscoId        String             @unique
  kiosco          Kiosco             @relation(fields: [kioscoId], references: [id], onDelete: Cascade)
  mpPreapprovalId String? // ID en MP para consultar estado real
  managementUrl   String? // Enlace de MercadoPago para gestionar la suscripción (init_point o permalink)
  status          SubscriptionStatus @default(PENDING)
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt
}

enum SubscriptionStatus {
  PENDING
  ACTIVE
  PAUSED
  CANCELLED
}

model AccessGrant {
  id          String          @id @default(cuid())
  kioscoId    String
  kiosco      Kiosco          @relation(fields: [kioscoId], references: [id], onDelete: Cascade)
  kind        AccessGrantKind
  startsAt    DateTime        @default(now())
  endsAt      DateTime
  note        String?         @db.Text
  createdById String?
  createdBy   User?           @relation("AccessGrantCreator", fields: [createdById], references: [id], onDelete: SetNull)
  revokedAt   DateTime?
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  @@index([kioscoId, startsAt, endsAt])
  @@index([createdById])
}

enum AccessGrantKind {
  ADMIN_GRACE
  ADMIN_INVITE
}

enum KioscoAccessOverride {
  INHERIT
  FORCE_ALLOW
  FORCE_BLOCK
}

enum PlatformProductStatus {
  APPROVED
  HIDDEN
}

enum PlatformProductSubmissionStatus {
  PENDING
  APPROVED
  REJECTED
}

enum MpIncomingPaymentChannel {
  MERCADOPAGO
  TRANSFER
}
